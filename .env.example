# Copy to .env and fill in. .env is gitignored.

# HuggingFace read token (accept WildChat-1M license first).
HF_TOKEN=

# Where HuggingFace caches dataset shards. No symlink on Windows; record this path.
# Example (Windows): C:\Users\you\.cache\huggingface
HF_HOME=

# LLM judge for H2 (templatedness) and H5 (substitutability). Anthropic key.
JUDGE_API_KEY=
